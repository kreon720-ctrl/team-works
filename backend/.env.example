# PostgreSQL Database Connection
DATABASE_URL=

# JWT Secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT Expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS: Frontend deployment URL (required for cross-origin API access)
# Development: http://localhost:3001
# Production: set to your Vercel frontend deployment URL
FRONTEND_URL=https://your-frontend.vercel.app

# Public frontend base URL used by OAuth callback redirects
PUBLIC_BASE_URL=http://localhost:3001

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/oauth/kakao/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
